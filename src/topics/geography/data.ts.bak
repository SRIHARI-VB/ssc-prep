  {
    id: 86, category: 'Indian Rivers', topic: 'Sabarmati River',
    question: 'On which river bank is Gandhi\'s Sabarmati Ashram located?',
    answer: 'Sabarmati River (Ahmedabad, Gujarat) — 371 km, originates in Rajasthan, flows through Gujarat into Gulf of Khambat',
    options: ['Sabarmati River (Ahmedabad, Gujarat) — 371 km, originates in Rajasthan, flows through Gujarat into Gulf of Khambat', 'Mahi River (Vadodara, Gujarat) — 583 km, originates in Vindhyas, flows through Gujarat into Gulf of Khambat', 'Narmada River (Bharuch, Gujarat) — 1,312 km, originates in Amarkantak, flows into Gulf of Khambat', 'Tapti River (Surat, Gujarat) — 724 km, originates in Satpura, flows through Gujarat into Gulf of Khambat'],
